version: '3'

services:
  # 1. 数据库：存储测试数据和向量
  db:
    image: ankane/pgvector:latest # 使用带向量扩展的 Postgres，方便后续 RAG
    container_name: chip_db
    restart: always
    environment:
      POSTGRES_DB: chip_data
      POSTGRES_USER: admin
      POSTGRES_PASSWORD: 3344520Qq # 请修改为你的密码
    ports:
      - "5432:5432"
    volumes:
      - ./postgres_data:/var/lib/postgresql/data

  # 2. 可视化看板：直观查看良率和分布
  grafana:
    image: grafana/grafana:latest
    container_name: chip_grafana
    restart: always
    ports:
      - "3000:3000"
    volumes:
      - ./grafana_data:/var/lib/grafana
    depends_on:
      - db

networks:
  default:
    name: chip_network
